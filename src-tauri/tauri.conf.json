{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NyaMarkdownor",
  "version": "1.0.3",
  "identifier": "io.github.stevennight.nyamarkdownor",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "devUrl": "http://127.0.0.1:8765",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NyaMarkdownor",
        "width": 1320,
        "height": 860,
        "minWidth": 420,
        "minHeight": 360,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; worker-src 'self' blob:; img-src 'self' asset: http://asset.localhost blob: data:; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "wix": {
        "upgradeCode": "95658019-a975-5c3e-9346-5b2db9134620"
      }
    },
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkdn", "mdwn"],
        "name": "Markdown Document",
        "description": "Markdown document",
        "role": "Editor",
        "mimeType": "text/markdown"
      },
      {
        "ext": ["txt"],
        "name": "Plain Text Document",
        "description": "Plain text document",
        "role": "Editor",
        "mimeType": "text/plain"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
